#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat >&2 <<EOF
Usage:
  $(basename "$0") tts TEXT
  $(basename "$0") stt
  $(basename "$0") llm PROMPT
EOF
    exit 2
}

die() {
    echo "$(basename "$0"): $*" >&2
    exit 1
}

if [ "${1:-}" = "--authenticated" ]; then
    shift
elif [ -z "${OIDC_ACCESS_TOKEN:-}" ]; then
    exec "$SCRIPT_DIR/with-oidc" \
        --client-id "${AI_OIDC_CLIENT_ID:-authentik-cli}" \
        -- "$0" --authenticated "$@"
fi

command -v curl >/dev/null || die "curl is required"
command -v jq >/dev/null || die "jq is required"

mode="${1:-}"
[ -n "$mode" ] || usage
shift

llm_url="${AI_LLM_URL:-https://llm.d-reis.com/v1}"
stt_url="${AI_STT_URL:-https://stt.d-reis.com/v1}"
tts_url="${AI_TTS_URL:-https://tts.d-reis.com/v1}"
auth_header="Authorization: Bearer $OIDC_ACCESS_TOKEN"

case "$mode" in
tts)
    [ "$#" -gt 0 ] || usage
    text="$*"
    temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/ai-tts.XXXXXX")"
    audio_file="$temp_dir/audio.wav"
    trap 'rm -rf "$temp_dir"' EXIT
    payload="$(jq -nc \
        --arg model "${AI_TTS_MODEL:-kyutai/pocket-tts}" \
        --arg voice "${AI_TTS_VOICE:-alba}" \
        --arg input "$text" \
        '{model: $model, voice: $voice, input: $input, response_format: "wav"}')"
    curl --fail-with-body -sS "$tts_url/audio/speech" \
        -H "$auth_header" -H 'Content-Type: application/json' \
        --data-binary "$payload" -o "$audio_file"
    if command -v afplay >/dev/null; then
        afplay "$audio_file"
    elif command -v play >/dev/null; then
        play -q "$audio_file"
    elif command -v ffplay >/dev/null; then
        ffplay -nodisp -autoexit -loglevel error "$audio_file"
    elif command -v mpv >/dev/null; then
        mpv --no-video --really-quiet "$audio_file"
    else
        die "no supported audio player found (afplay, play, ffplay, or mpv)"
    fi
    ;;
stt)
    [ "$#" -eq 0 ] || usage
    command -v rec >/dev/null || die "SoX rec is required for recording"
    temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/ai-stt.XXXXXX")"
    audio_file="$temp_dir/audio.wav"
    trap 'rm -rf "$temp_dir"' EXIT
    echo "Recording; press Ctrl-C to stop and transcribe." >&2
    record_status=0
    rec -q -c 1 -r 16000 -b 16 "$audio_file" || record_status=$?
    [ "$record_status" -eq 0 ] || [ "$record_status" -eq 130 ] || \
        die "recording failed with status $record_status"
    response="$(curl --fail-with-body -sS "$stt_url/audio/transcriptions" \
        -H "$auth_header" \
        -F "model=${AI_STT_MODEL:-nvidia/stt_en_fastconformer_hybrid_large_streaming_multi}" \
        -F "file=@$audio_file")"
    jq -er '.text' <<<"$response"
    ;;
llm)
    [ "$#" -gt 0 ] || usage
    prompt="$*"
    payload="$(jq -nc \
        --arg model "${AI_LLM_MODEL:-qwen3-4b}" \
        --arg system "${AI_LLM_SYSTEM_PROMPT:-Use tools when provided. Be concise.}" \
        --arg prompt "$prompt" \
        --argjson max_tokens "${AI_LLM_MAX_TOKENS:-384}" \
        '{model: $model, messages: [{role: "system", content: $system}, {role: "user", content: $prompt}], max_tokens: $max_tokens, stream: false}')"
    response="$(curl --fail-with-body -sS "$llm_url/chat/completions" \
        -H "$auth_header" -H 'Content-Type: application/json' \
        --data-binary "$payload")"
    jq -er '.choices[0].message.content' <<<"$response"
    ;;
*) usage ;;
esac
